{
  "name": "llm-providers",
  "$schema": "../../node_modules/nx/schemas/project.json",
  "sourceRoot": "libs/llm-providers/src",
  "projectType": "library",
  "tags": ["scope:shared", "type:providers"],
  "targets": {
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/libs/llm-providers"],
      "options": { "jestConfig": "libs/llm-providers/jest.config.ts", "passWithNoTests": true }
    },
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/llm-providers",
        "main": "libs/llm-providers/src/index.ts",
        "tsConfig": "libs/llm-providers/tsconfig.lib.json",
        "rootDir": "."
      }
    }
  }
}
