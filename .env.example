# ============================================================
# Custom AI Chatbot — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# App
PORT=3000
NODE_ENV=development

# ─── Database ────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/custom-ai-chatbot

# ─── Redis (Session Cache) ───────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── Qdrant (Vector DB) ──────────────────────────────────────
QDRANT_URL=http://localhost:6333

# ─── Security ────────────────────────────────────────────────
# Your secret key to access super-admin endpoints (keep this safe)
SUPER_ADMIN_KEY=change-this-to-a-long-random-secret

# JWT secret for admin dashboard login (change in production!)
JWT_SECRET=change-this-to-a-long-random-jwt-secret

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:4200,http://localhost:8100

# ─── LLM / Embedding (Sprint 2+) ─────────────────────────────
# Default OpenAI key used for embeddings (text-embedding-3-small).
# Tenants can override this with their own key via the admin dashboard.
OPENAI_API_KEY=sk-...

# Supported LLM providers: openai | anthropic | gemini | mistral
# LLM_PROVIDER=openai
