# ============================================================
# Custom AI Chatbot — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# App
PORT=3000
NODE_ENV=development

# ─── Database ────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/custom-ai-chatbot

# ─── Redis (Session Cache) ───────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── Qdrant (Vector DB) ──────────────────────────────────────
QDRANT_URL=http://localhost:6333

# ─── Security ────────────────────────────────────────────────
# Your secret key to access super-admin endpoints (keep this safe)
SUPER_ADMIN_KEY=change-this-to-a-long-random-secret

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:4200,http://localhost:8100

# ─── LLM Provider (set per tenant via admin dashboard) ───────
# These are NOT set here — each company provides their own keys
# via the admin dashboard. This section is for reference only.
#
# Supported providers: openai | anthropic | gemini | mistral
# LLM_PROVIDER=openai
# LLM_API_KEY=sk-...
